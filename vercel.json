{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/openings/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/candidates/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/pipeline/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/orgs/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/questions/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/skills/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/team",
      "destination": "/dashboard.html"
    },
    {
      "source": "/audit",
      "destination": "/dashboard.html"
    },
    {
      "source": "/assessments",
      "destination": "/dashboard.html"
    },
    {
      "source": "/hired",
      "destination": "/dashboard.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/dashboard",
      "destination": "/login",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/firebase-config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
