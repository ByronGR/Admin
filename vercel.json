{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/openings/:path*",   "destination": "/dashboard.html" },
    { "source": "/candidates/:path*", "destination": "/dashboard.html" },
    { "source": "/pipeline/:path*",   "destination": "/dashboard.html" },
    { "source": "/orgs/:path*",       "destination": "/dashboard.html" },
    { "source": "/apply/:path*",      "destination": "/dashboard.html" },
    { "source": "/dashboard",         "destination": "/dashboard.html" }
  ],
  "redirects": [
    { "source": "/",        "destination": "/login",    "permanent": false },
    { "source": "/admin",   "destination": "/login",    "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/firebase-config.js",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
